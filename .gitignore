__pycache__/
*.py[cod]

# Local hardware settings.
config/devices.local.json

# Large experiment artifacts. Use external storage, Git LFS, or force-add one-off captures.
data/captures/**
results/**
experiments/**
*.fc32
*.npy

# Keep placeholder docs in otherwise ignored artifact roots.
!data/README.md
!data/.gitkeep
!results/README.md
!results/.gitkeep
